              ← Voltar
            </button>
            <button onclick="doRegister()" id="regBtn"
              style="flex:2;padding:10px;background:linear-gradient(135deg,#7C3AED,#5B21B6);color:#fff;border:none;border-radius:9px;font-size:13px;font-weight:600;cursor:pointer">
