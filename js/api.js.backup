  document.getElementById('budgetModal')?.remove()
  const budgets = lead.customFields?.orcamentos || []

  const m = document.createElement('div')
  m.id = 'budgetModal'
  m.innerHTML = `
    <div style="position:fixed;inset:0;background:rgba(0,0,0,0.6);display:flex;align-items:center;justify-content:center;z-index:10000;padding:20px">
      <div style="background:#fff;border-radius:16px;width:100%;max-width:540px;max-height:90vh;overflow-y:auto">
        <div style="padding:24px 24px 0;display:flex;justify-content:space-between;align-items:center">
          <div>
            <div style="font-size:16px;font-weight:700;color:#111">Orçamentos</div>
            <div style="font-size:12px;color:#9CA3AF;margin-top:2px">${lead.name}</div>
          </div>
          <button onclick="document.getElementById('budgetModal').remove()" style="background:none;border:none;cursor:pointer;color:#9CA3AF;font-size:22px">✕</button>
        </div>
        <div style="padding:20px 24px">
          <!-- Lista existente -->
          <div id="budgetList">
            ${budgets.length ? budgets.map((b, i) => `
              <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 12px;background:#F9FAFB;border-radius:8px;margin-bottom:8px">
                <div>
                  <div style="font-size:13px;font-weight:600;color:#111">${b.procedimento}</div>
                  <div style="font-size:12px;color:#6B7280;margin-top:2px">${formatDate(b.data)}</div>
                </div>
                <div style="display:flex;align-items:center;gap:10px">
                  <div style="font-size:14px;font-weight:700;color:#10B981">${formatCurrency(b.valor)}</div>
                  <span style="
                    background:${b.status==='aberto' ? '#FFF7ED' : '#F0FDF4'};
                    color:${b.status==='aberto' ? '#EA580C' : '#16A34A'};
                    padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600
                  ">${b.status}</span>
                  <button onclick="removeBudget('${lead.id}',${i})" style="background:none;border:none;cursor:pointer;color:#9CA3AF;font-size:14px">✕</button>
                </div>
              </div>
            `).join('') : '<div style="text-align:center;padding:20px;color:#9CA3AF;font-size:13px">Nenhum orçamento cadastrado</div>'}
          </div>
          <!-- Novo orçamento -->
          <div style="border-top:1px solid #F3F4F6;padding-top:16px;margin-top:8px">
            <div style="font-size:12px;font-weight:700;color:#374151;margin-bottom:10px">NOVO ORÇAMENTO</div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px">
              <div>
                <label style="font-size:11px;font-weight:600;color:#6B7280;display:block;margin-bottom:4px">PROCEDIMENTO</label>
                <input id="bProcedimento" type="text" placeholder="Ex: Full Face 5D" style="width:100%;padding:8px 10px;border:1.5px solid #E5E7EB;border-radius:7px;font-size:13px;outline:none;box-sizing:border-box"/>
              </div>
              <div>
                <label style="font-size:11px;font-weight:600;color:#6B7280;display:block;margin-bottom:4px">VALOR (R$)</label>
                <input id="bValor" type="number" placeholder="0,00" style="width:100%;padding:8px 10px;border:1.5px solid #E5E7EB;border-radius:7px;font-size:13px;outline:none;box-sizing:border-box"/>
              </div>
              <div>
                <label style="font-size:11px;font-weight:600;color:#6B7280;display:block;margin-bottom:4px">STATUS</label>
                <select id="bStatus" style="width:100%;padding:8px 10px;border:1.5px solid #E5E7EB;border-radius:7px;font-size:13px;outline:none;background:#fff;box-sizing:border-box">
                  <option value="aberto">Aberto</option>
                  <option value="aprovado">Aprovado</option>
                  <option value="recusado">Recusado</option>
                </select>
              </div>
              <div>
                <label style="font-size:11px;font-weight:600;color:#6B7280;display:block;margin-bottom:4px">DATA</label>
                <input id="bData" type="date" style="width:100%;padding:8px 10px;border:1.5px solid #E5E7EB;border-radius:7px;font-size:13px;outline:none;box-sizing:border-box" value="${new Date().toISOString().split('T')[0]}"/>
              </div>
            </div>
            <div style="display:flex;gap:8px;justify-content:flex-end">
              <button onclick="document.getElementById('budgetModal').remove()" style="padding:8px 16px;background:#F3F4F6;color:#374151;border:none;border-radius:7px;font-size:12px;font-weight:600;cursor:pointer">Fechar</button>
              <button onclick="saveBudget('${lead.id}')" style="padding:8px 16px;background:#7C3AED;color:#fff;border:none;border-radius:7px;font-size:12px;font-weight:600;cursor:pointer">Adicionar</button>
            </div>
          </div>
        </div>
      </div>
    </div>`
  document.body.appendChild(m)
}

async function saveBudget(leadId) {
  const procedimento = document.getElementById('bProcedimento')?.value?.trim()
  const valor  = parseFloat(document.getElementById('bValor')?.value || '0')
  const status = document.getElementById('bStatus')?.value
  const data   = document.getElementById('bData')?.value
  if (!procedimento) { alert('Informe o procedimento'); return }

  const lead = await apiFetch(`/leads/${leadId}`)
  const orcamentos = [...(lead.customFields?.orcamentos || []), { procedimento, valor, status, data }]
  await apiFetch(`/leads/${leadId}`, {
    method: 'PUT',
    body: { customFields: { ...lead.customFields, orcamentos } },
  })
  document.getElementById('budgetModal')?.remove()
  // Reabrir com dados atualizados
  const updated = await apiFetch(`/leads/${leadId}`)
  showBudgetModal(updated)
  updateBudgetBadge(updated)
}

async function removeBudget(leadId, index) {
  const lead = await apiFetch(`/leads/${leadId}`)
  const orcamentos = [...(lead.customFields?.orcamentos || [])]
  orcamentos.splice(index, 1)
  await apiFetch(`/leads/${leadId}`, {
    method: 'PUT',
    body: { customFields: { ...lead.customFields, orcamentos } },
  })
  document.getElementById('budgetModal')?.remove()
  const updated = await apiFetch(`/leads/${leadId}`)
  showBudgetModal(updated)
  updateBudgetBadge(updated)
}

function updateBudgetBadge(lead) {
  const badge = document.getElementById('budgetBadge')
  if (!badge) return
  const open = (lead.customFields?.orcamentos || []).filter(b => b.status === 'aberto')
  if (open.length) {
    const total = open.reduce((s, b) => s + (b.valor || 0), 0)
    badge.innerHTML = `💰 ${open.length} orçamento${open.length > 1 ? 's' : ''} em aberto · ${formatCurrency(total)}`
    badge.style.background = '#FFF7ED'; badge.style.color = '#EA580C'; badge.style.borderColor = '#FED7AA'
  } else {
    badge.innerHTML = `💰 Sem orçamentos em aberto`
    badge.style.background = '#F9FAFB'; badge.style.color = '#9CA3AF'; badge.style.borderColor = '#E5E7EB'
  }
}

window.saveAnamnese   = saveAnamnese
window.showBudgetModal = showBudgetModal
window.saveBudget     = saveBudget
window.removeBudget   = removeBudget
window.showAnamneseModal = showAnamneseModal

// ─── Toggle item do histórico ────────────────────────────────
function toggleHistory(idx) {
  const el = document.getElementById(`hist_${idx}`)
  const icon = document.getElementById(`hist_icon_${idx}`)
  if (!el) return
  const open = el.style.display !== 'none'
  el.style.display = open ? 'none' : 'block'
  if (icon) icon.style.transform = open ? 'rotate(0deg)' : 'rotate(180deg)'
}
window.toggleHistory = toggleHistory

// ─── Modal principal do paciente ─────────────────────────────
function showLeadModal(lead) {
  document.getElementById('leadModal')?.remove()

  _currentLeadId = lead.id
  _currentCustomProtocols = lead.customFields?.careProtocols || []

  const tags = (lead.lead_tags || []).map(lt =>
    `<span style="background:${lt.tag.color}22;color:${lt.tag.color};padding:4px 12px;border-radius:20px;font-size:12px;font-weight:500">${lt.tag.name}</span>`
  ).join(' ')

  const appts = (lead.appointments || []).sort((a, b) => new Date(b.scheduledAt) - new Date(a.scheduledAt))
  const budgets = lead.customFields?.orcamentos || []
  const openBudgets = budgets.filter(b => b.status === 'aberto')
  const hasAnamnese = Object.keys(lead.customFields?.anamnese || {}).length > 0

  const historyItems = appts.map((a, i) => {
    const statusColor = { attended:'#16A34A', scheduled:'#2563EB', confirmed:'#7C3AED', cancelled:'#DC2626', no_show:'#DC2626' }
    const statusBg    = { attended:'#F0FDF4', scheduled:'#EFF6FF', confirmed:'#F5F3FF', cancelled:'#FEF2F2', no_show:'#FEF2F2' }
    return `
      <div style="border:1px solid #F3F4F6;border-radius:10px;overflow:hidden;margin-bottom:8px">
        <div onclick="toggleHistory(${i})" style="
          display:flex;justify-content:space-between;align-items:center;
          padding:12px 14px;cursor:pointer;background:#FAFAFA;
          user-select:none;
        ">
          <div style="display:flex;align-items:center;gap:12px">
            <div style="
              width:8px;height:8px;border-radius:50%;flex-shrink:0;
              background:${statusColor[a.status] || '#9CA3AF'}
            "></div>
            <div>
              <div style="font-size:13px;font-weight:600;color:#111">${a.procedure?.name || 'Consulta'}</div>
              <div style="font-size:11px;color:#9CA3AF;margin-top:1px">${formatDate(a.scheduledAt)}</div>
            </div>
          </div>
          <div style="display:flex;align-items:center;gap:10px">
            ${a.procedure?.price ? `<span style="font-size:13px;font-weight:600;color:#10B981">${formatCurrency(a.procedure.price)}</span>` : ''}
            <span style="background:${statusBg[a.status]||'#F9FAFB'};color:${statusColor[a.status]||'#6B7280'};padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600">${a.status}</span>
            <span id="hist_icon_${i}" style="color:#9CA3AF;font-size:14px;transition:transform .2s">▼</span>
          </div>
        </div>
        <div id="hist_${i}" style="display:none;padding:12px 14px;border-top:1px solid #F3F4F6;background:#fff">
          ${a.notes ? `<div style="font-size:12px;color:#6B7280;margin-bottom:6px"><b>Observações:</b> ${a.notes}</div>` : ''}
          <div style="font-size:12px;color:#9CA3AF">
            Duração: ${a.durationMinutes || 60} min
            ${a.procedure?.category ? ` · Categoria: ${a.procedure.category}` : ''}
          </div>
        </div>
      </div>`
  }).join('')

  const modal = document.createElement('div')
  modal.id = 'leadModal'
  modal.innerHTML = `
    <div style="
      position:fixed;inset:0;background:rgba(0,0,0,0.6);
      display:flex;align-items:center;justify-content:center;z-index:9998;padding:16px
    " onclick="if(event.target===this)this.remove()">
      <div style="
        background:#fff;border-radius:18px;width:100%;max-width:1080px;
        height:92vh;display:flex;flex-direction:column;overflow:hidden;
        box-shadow:0 24px 80px rgba(0,0,0,0.25);
      ">

        <!-- ══ HEADER FIXO ══ -->
        <div style="
          padding:20px 28px;border-bottom:1px solid #F3F4F6;
          display:flex;justify-content:space-between;align-items:flex-start;flex-shrink:0;
          background:#fff;
        ">
          <div style="display:flex;gap:16px;align-items:flex-start">
            <!-- Avatar -->
            <div style="
              width:52px;height:52px;border-radius:50%;flex-shrink:0;
              background:linear-gradient(135deg,#7C3AED,#C9A96E);
              display:flex;align-items:center;justify-content:center;
              font-size:20px;font-weight:700;color:#fff;
            ">${lead.name.charAt(0)}</div>
            <div>
              <h2 style="margin:0;font-size:19px;font-weight:700;color:#111">${lead.name}</h2>
              <div style="font-size:13px;color:#6B7280;margin-top:3px">
                📞 ${lead.phone}${lead.email ? ` · ✉️ ${lead.email}` : ''}
              </div>
              <div style="margin-top:8px;display:flex;gap:6px;flex-wrap:wrap">${tags}</div>
            </div>
