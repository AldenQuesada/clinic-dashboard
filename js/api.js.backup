        <div id="regSuccess" style="display:none;background:#F0FDF4;color:#15803D;padding:16px;border-radius:10px;text-align:center;font-size:13px;margin-bottom:14px"></div>

        <div id="regForm">
          <div style="margin-bottom:14px">
