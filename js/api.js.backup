// ══════════════════════════════════════════════════════════════
// SDR — Funil, Responsável, Metas Editáveis
// ══════════════════════════════════════════════════════════════

const SDR_KEY = 'clinicai_sdr_config'

function sdrGetConfig() {
  try { return JSON.parse(localStorage.getItem(SDR_KEY) || '{}') } catch { return {} }
}
function sdrSaveConfig(cfg) { localStorage.setItem(SDR_KEY, JSON.stringify(cfg)) }

/** Preenche o select de responsáveis com profissionais cadastrados */
function sdrPopulateResp(prefix) {
  const sel = document.getElementById(`${prefix}_responsavel`)
  if (!sel) return
  const profs = getProfessionals ? getProfessionals() : []
  const cfg   = sdrGetConfig()
  const saved = cfg[`${prefix}_resp`] || ''
  sel.innerHTML = '<option value="">Selecione...</option>' +
    profs.map(p => `<option value="${p.nome}" ${p.nome === saved ? 'selected' : ''}>${p.nome}${p.especialidade ? ' — ' + p.especialidade : ''}</option>`).join('')
  if (!profs.length) sel.innerHTML = '<option value="">Nenhum profissional cadastrado</option>'
}

function sdrSaveResp(type, val) {
  const cfg = sdrGetConfig()
  cfg[`${type === 'fullface' ? 'sdrff' : 'sdrpt'}_resp`] = val
  sdrSaveConfig(cfg)
}

function sdrSetPeriod(type, period, btn) {
  const prefix = type === 'fullface' ? 'sdrff' : 'sdrpt'
  const wrap = document.querySelector(`#page-${type === 'fullface' ? 'sdh-fullface' : 'sdh-protocolos'} .sdr-period-btn`)?.closest('div')
  if (wrap) wrap.querySelectorAll('.sdr-period-btn').forEach(b => b.classList.remove('active'))
  if (btn) btn.classList.add('active')
  sdrLoadFunnel(prefix)
}

/** Calcula cor de conversão vs meta */
function _sdrPctColor(actual, target) {
  if (actual >= target) return 'green'
  if (actual >= target * 0.7) return 'orange'
  return 'red'
}

/** Renderiza tags de um estágio */
function _sdrRenderTags(elId, tags) {
  const el = document.getElementById(elId)
  if (!el) return
  el.innerHTML = tags.map(t => `<span class="sdr-tag-chip">${t}</span>`).join('')
}

/** Carrega e renderiza o funil para um prefix (sdrff ou sdrpt) */
async function sdrLoadFunnel(prefix) {
  const type    = prefix === 'sdrff' ? 'fullface' : 'protocolos'
  const cfg     = sdrGetConfig()
  const metaAg  = parseFloat(cfg[`${prefix}_meta_ag`]  || '50')
  const metaComp= parseFloat(cfg[`${prefix}_meta_comp`]|| '80')

  // Atualiza valores de meta na UI
  const mAg   = document.getElementById(`${prefix}_meta_ag`)
  const mComp = document.getElementById(`${prefix}_meta_comp`)
  if (mAg)   mAg.textContent   = `${metaAg}%`
  if (mComp) mComp.textContent = `${metaComp}%`

  try {
    // Busca leads do tipo correto
    const leadsRaw = await apiFetch(`/leads?limit=500`)
    const leads    = Array.isArray(leadsRaw.data) ? leadsRaw.data : (Array.isArray(leadsRaw) ? leadsRaw : [])

    // Filtra por funil (Full Face ou Protocolos)
    const keyword = type === 'fullface' ? 'full' : 'protocolo'
    const relevant = leads.filter(l => {
      const src = (l.source || l.canal || l.tag || l.category || '').toLowerCase()
      return type === 'fullface' ? (src.includes('full') || src.includes('face')) : (src.includes('protocolo'))
    })

    // Se não há filtro natural, usa todos (demo mode)
    const pool = relevant.length > 0 ? relevant : leads

    const novos       = pool.length
    const agendados   = pool.filter(l => ['scheduled','confirmed','attended'].includes(l.status)).length
    const compareceram= pool.filter(l => l.status === 'attended').length
    const pacientes   = pool.filter(l => l.status === 'patient' || l.isPatient).length
    const noShows     = pool.filter(l => l.status === 'noshow' || l.noShow).length

    const pctAg   = novos       > 0 ? Math.round(agendados    / novos       * 100) : 0
    const pctComp = agendados   > 0 ? Math.round(compareceram / agendados   * 100) : 0
    const pctPac  = compareceram> 0 ? Math.round(pacientes    / compareceram* 100) : 0

    // Atualiza contagens
    const setEl = (id, val) => { const el = document.getElementById(id); if (el) el.textContent = val }
    setEl(`${prefix}_c1`, novos)
    setEl(`${prefix}_c2`, agendados)
    setEl(`${prefix}_c3`, compareceram)
    setEl(`${prefix}_c4`, pacientes)

    // Percentuais com cor
    const p12 = document.getElementById(`${prefix}_p12`)
    const p23 = document.getElementById(`${prefix}_p23`)
    const p34 = document.getElementById(`${prefix}_p34`)
    if (p12) { p12.textContent = `${pctAg}%`;   p12.className = `sdr-arrow-pct ${_sdrPctColor(pctAg, metaAg)}` }
    if (p23) { p23.textContent = `${pctComp}%`;  p23.className = `sdr-arrow-pct ${_sdrPctColor(pctComp, metaComp)}` }
    if (p34) { p34.textContent = `${pctPac}%`;   p34.className = `sdr-arrow-pct` }

    // No-show badge
    const nsBadge = document.getElementById(`${prefix}_noshow`)
    const nsCount = document.getElementById(`${prefix}_noshow_count`)
    if (nsBadge && noShows > 0) { nsBadge.style.display = 'flex'; if (nsCount) nsCount.textContent = noShows }

    // Tags por estágio (de anamnese/tags do lead)
    const tagsNovos       = [...new Set(pool.slice(0,5).flatMap(l => l.tags || []))].slice(0,3)
    const tagsAgendados   = [...new Set(pool.filter(l => agendados > 0).flatMap(l => l.tags || []))].slice(0,2)
    _sdrRenderTags(`${prefix}_t1`, tagsNovos.length ? tagsNovos : ['Novo'])
    _sdrRenderTags(`${prefix}_t2`, tagsAgendados.length ? tagsAgendados : ['Agendado'])
    _sdrRenderTags(`${prefix}_t3`, compareceram > 0 ? ['Compareceu'] : [])
    _sdrRenderTags(`${prefix}_t4`, pacientes > 0 ? ['Paciente'] : [])

    // Temperatura (por score se disponível)
    const hot  = pool.filter(l => (l.score || 0) >= 70).length
    const warm = pool.filter(l => (l.score || 0) >= 40 && (l.score || 0) < 70).length
    const cold = pool.filter(l => (l.score || 0) < 40).length
    setEl(`${prefix}_hot`,  hot  || Math.round(novos * 0.3))
    setEl(`${prefix}_warm`, warm || Math.round(novos * 0.5))
    setEl(`${prefix}_cold`, cold || Math.round(novos * 0.2))

  } catch (e) {
    // Modo demo — mostra dados ilustrativos
    const demo = type === 'fullface'
      ? { c1:124, c2:68, c3:54, c4:48, p12:55, p23:79, p34:89 }
      : { c1:87,  c2:41, c3:35, c4:30, p12:47, p23:85, p34:86 }

    const setEl = (id, val) => { const el = document.getElementById(id); if (el) el.textContent = val }
    setEl(`${prefix}_c1`, demo.c1)
    setEl(`${prefix}_c2`, demo.c2)
    setEl(`${prefix}_c3`, demo.c3)
    setEl(`${prefix}_c4`, demo.c4)

    const p12 = document.getElementById(`${prefix}_p12`)
    const p23 = document.getElementById(`${prefix}_p23`)
    const p34 = document.getElementById(`${prefix}_p34`)
    if (p12) { p12.textContent = `${demo.p12}%`; p12.className = `sdr-arrow-pct ${_sdrPctColor(demo.p12, metaAg)}` }
    if (p23) { p23.textContent = `${demo.p23}%`; p23.className = `sdr-arrow-pct ${_sdrPctColor(demo.p23, metaComp)}` }
    if (p34) { p34.textContent = `${demo.p34}%` }

    _sdrRenderTags(`${prefix}_t1`, ['WhatsApp', 'Instagram'])
    _sdrRenderTags(`${prefix}_t2`, ['Agendado', 'Qualificado'])
    _sdrRenderTags(`${prefix}_t3`, ['Compareceu'])
    _sdrRenderTags(`${prefix}_t4`, ['Paciente', 'Ativo'])
    setEl(`${prefix}_hot`, Math.round(demo.c1 * 0.3))
    setEl(`${prefix}_warm`, Math.round(demo.c1 * 0.5))
    setEl(`${prefix}_cold`, Math.round(demo.c1 * 0.2))
  }
}

/** Meta editável — clique na span abre input inline */
function sdrEditMeta(type, kind, el) {
  const prefix  = type === 'fullface' ? 'sdrff' : 'sdrpt'
  const cfgKey  = kind === 'agendamento' ? `${prefix}_meta_ag` : `${prefix}_meta_comp`
  const current = parseFloat(el.textContent) || (kind === 'agendamento' ? 50 : 80)

  const input = document.createElement('input')
  input.type  = 'number'; input.min = '1'; input.max = '100'
  input.value = current
  input.style.cssText = 'width:46px;border:1.5px solid #7C3AED;border-radius:5px;padding:1px 4px;font-size:11px;font-weight:700;color:#7C3AED;outline:none;text-align:center'
  el.replaceWith(input)
  input.focus(); input.select()

  const save = () => {
    const val = Math.min(100, Math.max(1, parseInt(input.value) || current))
    const span = document.createElement('span')
    span.className = 'sdr-target-val'
    span.id = el.id
    span.textContent = `${val}%`
    span.title = 'Clique para editar'
    span.onclick = () => sdrEditMeta(type, kind, span)
    input.replaceWith(span)
    const cfg = sdrGetConfig()
    cfg[cfgKey] = val
    sdrSaveConfig(cfg)
    sdrLoadFunnel(prefix)
  }
  input.addEventListener('blur', save)
  input.addEventListener('keydown', e => { if (e.key === 'Enter') save() })
}

function sdrSaveNoshowCause(sel) {
  const item = sel.closest('.sdr-ns-item')
  const name = item?.querySelector('.sdr-ns-name')?.textContent || ''
  if (sel.value) showToast(`Causa registrada para ${name}: ${sel.options[sel.selectedIndex].text}`, 'success')
}

window.sdrSaveResp       = sdrSaveResp
window.sdrSetPeriod      = sdrSetPeriod
window.sdrEditMeta       = sdrEditMeta
window.sdrSaveNoshowCause= sdrSaveNoshowCause

// ── Hook na navegação do menu ─────────────────────────────────
const _origNavigateTo = window.navigateTo
window.navigateTo = function(pageId) {
  _origNavigateTo(pageId)
  // Mostrar seletor de período só no dashboard
  const _pd = document.getElementById('periodDropdown')
  if (_pd) _pd.style.display = (pageId === 'dashboard-overview') ? '' : 'none'

  setTimeout(() => {
    if (pageId === 'agenda-overview') { loadAgendaOverview() }
    if (pageId === 'agenda') { _agendaView = 'semana'; _agendaDate = new Date(); renderAgenda() }
    if (pageId === 'agenda-reports') { if (window.renderAgendaRelatorios) renderAgendaRelatorios() }
    if (pageId === 'agenda-eventos') { if (window.renderAgendaEventos)    renderAgendaEventos() }
    if (pageId === 'agenda-tags')    { if (window.renderAgendaTagsFluxos) renderAgendaTagsFluxos() }
    if (pageId === 'sdh-fullface')   { sdrPopulateResp('sdrff'); sdrLoadFunnel('sdrff') }
    if (pageId === 'sdh-protocolos') { sdrPopulateResp('sdrpt'); sdrLoadFunnel('sdrpt') }
    // compatibilidade com ids antigos
    if (pageId === 'agenda-today') { _agendaView = 'hoje'; _agendaDate = new Date(); renderAgenda() }
    if (pageId === 'agenda-full')  { _agendaView = 'mes';  _agendaDate = new Date(); renderAgenda() }
  }, 30)
}

