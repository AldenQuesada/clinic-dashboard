  const roleLabels = { admin: 'Administrador', gestor: 'Gestor', comercial: 'Comercial', atendimento: 'Atendimento', owner: 'Proprietário', esteticista: 'Esteticista', financeiro: 'Financeiro', marketing: 'Marketing' }
