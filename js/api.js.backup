            <button onclick="document.getElementById('leadModal').remove()" style="
              width:36px;height:36px;border-radius:50%;background:#F3F4F6;border:none;
              cursor:pointer;font-size:18px;color:#6B7280;display:flex;align-items:center;justify-content:center;
              font-weight:300;flex-shrink:0;
            ">✕</button>
          </div>
        </div>

        <!-- ══ CONTEÚDO SCROLLÁVEL ══ -->
        <div style="overflow-y:auto;flex:1;padding:24px 28px">

          <!-- KPIs -->
          <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:24px">
            <div style="background:linear-gradient(135deg,#F0FDF4,#DCFCE7);border-radius:12px;padding:16px;text-align:center">
              <div style="font-size:20px;font-weight:800;color:#16A34A">${formatCurrency(lead.patient?.totalRevenue)}</div>
              <div style="font-size:11px;color:#15803D;font-weight:600;margin-top:3px">Total Gasto</div>
            </div>
            <div style="background:linear-gradient(135deg,#EFF6FF,#DBEAFE);border-radius:12px;padding:16px;text-align:center">
              <div style="font-size:20px;font-weight:800;color:#2563EB">${appts.length}</div>
              <div style="font-size:11px;color:#1D4ED8;font-weight:600;margin-top:3px">Consultas</div>
            </div>
            <div style="background:linear-gradient(135deg,#F5F3FF,#EDE9FE);border-radius:12px;padding:16px;text-align:center">
              <div style="font-size:20px;font-weight:800;color:#7C3AED">${lead.leadScore || 0}</div>
              <div style="font-size:11px;color:#6D28D9;font-weight:600;margin-top:3px">Lead Score</div>
            </div>
            <div style="background:linear-gradient(135deg,#FFF7ED,#FED7AA);border-radius:12px;padding:16px;text-align:center">
