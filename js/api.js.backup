/**
 * ClinicAI — API Integration Layer
 * Conecta o dashboard ao backend em http://localhost:3001
 */

const API_BASE = `${window.location.origin}/api/v1`

// ─── Auth ────────────────────────────────────────────────────
function getToken() {
  return localStorage.getItem('clinicai_token')
}

function setToken(token) {
  localStorage.setItem('clinicai_token', token)
}

function clearToken() {
  localStorage.removeItem('clinicai_token')
  localStorage.removeItem('clinicai_user')
  localStorage.removeItem('clinicai_remember')
  localStorage.removeItem('clinicai_pw') // limpa se existia de versão anterior
  sessionStorage.removeItem('clinicai_user')
}

function getUser() {
  try {
    const src = localStorage.getItem('clinicai_remember') ? localStorage : sessionStorage
    return JSON.parse(src.getItem('clinicai_user') || localStorage.getItem('clinicai_user') || 'null')
  } catch { return null }
}

function isLoggedIn() {
  return !!getToken()
}

// ─── Fetch helper ────────────────────────────────────────────
async function apiFetch(path, options = {}) {
  const token = getToken()
  const res = await fetch(`${API_BASE}${path}`, {
    ...options,
    headers: {
      'Content-Type': 'application/json',
      ...(token ? { Authorization: `Bearer ${token}` } : {}),
      ...(options.headers || {}),
    },
    body: options.body ? JSON.stringify(options.body) : undefined,
  })

  if (res.status === 401) {
    clearToken()
    showLoginModal()
    throw new Error('Sessão expirada')
  }

  const ct = res.headers.get('content-type') || ''
  if (!ct.includes('application/json')) {
    throw new Error(`Resposta inesperada do servidor (${res.status})`)
  }

  return res.json()
}

// ─── Login modal ─────────────────────────────────────────────
function showLoginModal() {
  document.getElementById('loginModal')?.remove()

  const modal = document.createElement('div')
  modal.id = 'loginModal'
  modal.innerHTML = `
    <div style="position:fixed;inset:0;background:rgba(0,0,0,0.7);display:flex;align-items:center;justify-content:center;z-index:9999;">
      <div style="background:#fff;border-radius:20px;padding:40px;width:400px;box-shadow:0 24px 80px rgba(0,0,0,0.3);">
        <div style="text-align:center;margin-bottom:28px">
          <div style="width:56px;height:56px;background:#7C3AED;border-radius:14px;display:inline-flex;align-items:center;justify-content:center;margin-bottom:14px">
            <svg width="28" height="28" fill="none" stroke="#fff" stroke-width="2" viewBox="0 0 24 24"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
          </div>
          <h2 style="margin:0;font-size:22px;font-weight:700;color:#111">ClinicAI</h2>
          <p style="margin:6px 0 0;color:#6B7280;font-size:14px">Faça login para continuar</p>
        </div>

        <div id="loginError" style="display:none;background:#FEE2E2;color:#DC2626;padding:10px 14px;border-radius:8px;font-size:13px;margin-bottom:16px;text-align:center"></div>

        <!-- Google Login -->
        <div id="googleBtnWrapper" style="margin-bottom:16px">
          <div id="g_id_signin" style="display:flex;justify-content:center"></div>
        </div>

        <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px">
          <div style="flex:1;height:1px;background:#E5E7EB"></div>
          <span style="font-size:12px;color:#9CA3AF;white-space:nowrap">ou entre com e-mail</span>
          <div style="flex:1;height:1px;background:#E5E7EB"></div>
        </div>

        <!-- Form com name attributes para o browser oferecer salvar senha -->
        <form id="loginForm" onsubmit="event.preventDefault();doLogin()" autocomplete="on">
          <div style="margin-bottom:14px">
            <label style="display:block;font-size:13px;font-weight:500;color:#374151;margin-bottom:6px">E-mail</label>
            <input id="loginEmail" name="email" type="email" autocomplete="email" placeholder="seu@email.com.br" style="width:100%;padding:10px 12px;border:1.5px solid #D1D5DB;border-radius:8px;font-size:14px;outline:none;box-sizing:border-box;" />
          </div>
          <div style="margin-bottom:10px">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px">
              <label style="font-size:13px;font-weight:500;color:#374151">Senha</label>
              <button type="button" onclick="showForgotPasswordModal()" style="background:none;border:none;font-size:12px;color:#7C3AED;cursor:pointer;padding:0;font-weight:500">Esqueci minha senha</button>
            </div>
            <div style="position:relative">
              <input id="loginPassword" name="password" type="password" autocomplete="current-password" placeholder="••••••••" style="width:100%;padding:10px 40px 10px 12px;border:1.5px solid #D1D5DB;border-radius:8px;font-size:14px;outline:none;box-sizing:border-box;" />
              <button type="button" onclick="togglePassVis('loginPassword','loginPwEye')" style="position:absolute;right:10px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:#9CA3AF;padding:0;display:flex;align-items:center">
                <svg id="loginPwEye" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              </button>
            </div>
          </div>
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:20px">
            <input id="loginRemember" name="remember" type="checkbox" style="width:15px;height:15px;accent-color:#7C3AED;cursor:pointer"/>
            <label for="loginRemember" style="font-size:13px;color:#374151;cursor:pointer">Lembrar minha senha neste dispositivo</label>
          </div>
          <button id="loginBtn" type="submit" style="width:100%;padding:12px;background:linear-gradient(135deg,#7C3AED,#5B21B6);color:#fff;border:none;border-radius:9px;font-size:15px;font-weight:600;cursor:pointer;">Entrar</button>
        </form>
        <div style="text-align:center;margin-top:18px;padding-top:16px;border-top:1px solid #F3F4F6">
          <span style="font-size:13px;color:#6B7280">Ainda não tem acesso? </span>
          <button type="button" onclick="showRegisterModal()" style="background:none;border:none;font-size:13px;color:#7C3AED;cursor:pointer;font-weight:600;padding:0">Solicitar cadastro →</button>
        </div>
      </div>
    </div>
  `
  document.body.appendChild(modal)

  // Inicializa Google Sign-In se o script já carregou
  _initGoogleSignIn()
}

function _saveSession(data, pw) {
  const remember = document.getElementById('loginRemember')?.checked ?? true
  setToken(data.token)
  if (remember) {
    localStorage.setItem('clinicai_user', JSON.stringify(data.user))
    localStorage.setItem('clinicai_remember', '1')
  } else {
    sessionStorage.setItem('clinicai_user', JSON.stringify(data.user))
    localStorage.removeItem('clinicai_remember')
  }
  // Nota: senha não é armazenada em localStorage por segurança
}

async function doLogin() {
  const email    = document.getElementById('loginEmail').value
  const password = document.getElementById('loginPassword').value
  const btn      = document.getElementById('loginBtn')
  const errEl    = document.getElementById('loginError')

  btn.textContent = 'Entrando...'
  btn.disabled = true
  errEl.style.display = 'none'

  try {
    const data = await apiFetch('/auth/login', { method: 'POST', body: { email, password } })
    if (data.error) throw new Error(data.error)
    _saveSession(data, password)
    document.getElementById('loginModal')?.remove()
    loadDashboardData()
  } catch (err) {
    errEl.textContent = err.message || 'Erro ao fazer login'
    errEl.style.display = 'block'
    btn.textContent = 'Entrar'
    btn.disabled = false
  }
}
window.doLogin = doLogin

// ─── Google Sign-In ──────────────────────────────────────────
function _initGoogleSignIn() {
  if (!window.google?.accounts?.id) return
  // Client ID vem do meta tag ou do backend — aqui usamos um placeholder
  // O usuário precisa configurar GOOGLE_CLIENT_ID no .env e adicionar o meta tag
  const clientId = document.querySelector('meta[name="google-client-id"]')?.content
  if (!clientId) return
  window.google.accounts.id.initialize({
    client_id: clientId,
    callback:  handleGoogleLogin,
    auto_select: false,
  })
  window.google.accounts.id.renderButton(
    document.getElementById('g_id_signin'),
    { theme: 'outline', size: 'large', width: 320, text: 'signin_with', logo_alignment: 'left' }
  )
}

async function handleGoogleLogin(response) {
  const errEl = document.getElementById('loginError')
  try {
    const data = await apiFetch('/auth/google', { method: 'POST', body: { credential: response.credential } })
    if (data.error) {
      if (errEl) { errEl.textContent = data.error; errEl.style.display = 'block' }
      return
    }
    _saveSession(data)
    document.getElementById('loginModal')?.remove()
    loadDashboardData()
  } catch (err) {
    if (errEl) { errEl.textContent = err.message || 'Erro ao entrar com Google'; errEl.style.display = 'block' }
  }
}
window.handleGoogleLogin = handleGoogleLogin

function doLogout() {
  if (!confirm('Deseja sair da conta?')) return
  clearToken()
  showLoginModal()
}
window.doLogout = doLogout

function showForgotPasswordModal() {
  document.getElementById('loginModal')?.remove()
  document.getElementById('forgotModal')?.remove()
  const m = document.createElement('div')
  m.id = 'forgotModal'
  m.innerHTML = `
    <div style="position:fixed;inset:0;background:rgba(0,0,0,0.7);display:flex;align-items:center;justify-content:center;z-index:9999">
      <div style="background:#fff;border-radius:16px;padding:40px;width:380px;box-shadow:0 20px 60px rgba(0,0,0,0.3)">
        <div style="text-align:center;margin-bottom:24px">
          <div style="width:48px;height:48px;background:#EDE9FE;border-radius:12px;display:inline-flex;align-items:center;justify-content:center;margin-bottom:12px">
            <svg width="22" height="22" fill="none" stroke="#7C3AED" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          </div>
          <h2 style="margin:0;font-size:20px;font-weight:700;color:#111">Recuperar Senha</h2>
          <p style="margin:6px 0 0;color:#6B7280;font-size:13px">Informe seu e-mail para receber as instruções</p>
        </div>
        <div id="forgotMsg" style="display:none;background:#F0FDF4;color:#15803D;padding:10px 14px;border-radius:8px;font-size:13px;margin-bottom:16px;text-align:center"></div>
        <div id="forgotErr" style="display:none;background:#FEE2E2;color:#DC2626;padding:10px 14px;border-radius:8px;font-size:13px;margin-bottom:16px;text-align:center"></div>
        <div style="margin-bottom:20px">
          <label style="display:block;font-size:13px;font-weight:500;color:#374151;margin-bottom:6px">E-mail cadastrado</label>
          <input id="forgotEmail" type="email" placeholder="seu@email.com.br" style="width:100%;padding:10px 12px;border:1.5px solid #D1D5DB;border-radius:8px;font-size:14px;outline:none;box-sizing:border-box"/>
        </div>
        <button onclick="doForgotPassword()" style="width:100%;padding:12px;background:#7C3AED;color:#fff;border:none;border-radius:8px;font-size:15px;font-weight:600;cursor:pointer" id="forgotBtn">Enviar instruções</button>
        <button onclick="document.getElementById('forgotModal').remove();showLoginModal()" style="width:100%;padding:10px;background:none;border:none;font-size:13px;color:#6B7280;cursor:pointer;margin-top:10px">Voltar ao login</button>
      </div>
    </div>`
  document.body.appendChild(m)
  document.getElementById('forgotEmail')?.focus()
  document.getElementById('forgotEmail')?.addEventListener('keydown', e => { if (e.key === 'Enter') doForgotPassword() })
}

async function doForgotPassword() {
  const email = document.getElementById('forgotEmail')?.value?.trim()
  const msgEl = document.getElementById('forgotMsg')
  const errEl = document.getElementById('forgotErr')
  const btn   = document.getElementById('forgotBtn')
  if (!email) { errEl.textContent = 'Informe seu e-mail'; errEl.style.display = 'block'; return }
  btn.textContent = 'Enviando...'
  btn.disabled = true
  errEl.style.display = 'none'
  // Simula envio (backend não tem endpoint de recuperação ainda)
  await new Promise(r => setTimeout(r, 1200))
  msgEl.textContent = 'Se este e-mail estiver cadastrado, você receberá as instruções em breve.'
  msgEl.style.display = 'block'
  btn.style.display = 'none'
}

window.showForgotPasswordModal = showForgotPasswordModal
window.doForgotPassword        = doForgotPassword

