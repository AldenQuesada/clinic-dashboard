# Alexa Bridge — Configuracao
# Copie para .env e preencha os valores

# Porta do servidor
PORT=3456

# Token de autenticacao (opcional, mas recomendado)
AUTH_TOKEN=seu-token-seguro-aqui

# Amazon page (BR = amazon.com.br)
AMAZON_PAGE=amazon.com.br

# Cookie da sessao Amazon (preenchido automaticamente apos primeiro login)
# Ou cole manualmente se ja tiver
ALEXA_COOKIE=

# Arquivo de cookie persistido (alternativa ao ALEXA_COOKIE)
ALEXA_COOKIE_FILE=.alexa-cookie

# Proxy de login (usado apenas na primeira autenticacao)
PROXY_HOST=localhost
PROXY_PORT=3457
