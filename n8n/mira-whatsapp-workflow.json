    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-haiku-4-5-20251001\",\n  \"max_tokens\": 512,\n  \"system\": \"Voce eh a Mira, assistente WhatsApp da clinica da Dra Mirian. Usuario eh um profissional. Escolha a tool apropriada pra responder. Se pedirem algo fora das tools, responda em texto curto educadamente que voce nao pode ajudar com isso agora.\",\n  \"tools\": [\n    {\"name\":\"get_agenda\",\"description\":\"Consulta a agenda de um dia especifico. date_offset: 0=hoje, 1=amanha, -1=ontem, etc.\",\"input_schema\":{\"type\":\"object\",\"properties\":{\"date_offset\":{\"type\":\"integer\"}},\"required\":[\"date_offset\"]}},\n    {\"name\":\"get_free_slots\",\"description\":\"Horarios livres num dia. date_offset: 0=hoje, 1=amanha.\",\"input_schema\":{\"type\":\"object\",\"properties\":{\"date_offset\":{\"type\":\"integer\"}},\"required\":[\"date_offset\"]}},\n    {\"name\":\"search_patients\",\"description\":\"Busca pacientes por nome ou telefone.\",\"input_schema\":{\"type\":\"object\",\"properties\":{\"query\":{\"type\":\"string\"}},\"required\":[\"query\"]}},\n    {\"name\":\"get_patient_balance\",\"description\":\"Saldo financeiro de um paciente.\",\"input_schema\":{\"type\":\"object\",\"properties\":{\"name\":{\"type\":\"string\"}},\"required\":[\"name\"]}},\n    {\"name\":\"get_finance_summary\",\"description\":\"Resumo de receita num periodo (hoje, semana, mes).\",\"input_schema\":{\"type\":\"object\",\"properties\":{\"period\":{\"type\":\"string\",\"enum\":[\"hoje\",\"semana\",\"mes\"]}},\"required\":[\"period\"]}},\n    {\"name\":\"get_commission\",\"description\":\"Comissao do profissional num periodo.\",\"input_schema\":{\"type\":\"object\",\"properties\":{\"period\":{\"type\":\"string\",\"enum\":[\"hoje\",\"semana\",\"mes\"]}},\"required\":[\"period\"]}},\n    {\"name\":\"list_payments\",\"description\":\"Lista pagamentos recebidos num periodo.\",\"input_schema\":{\"type\":\"object\",\"properties\":{\"period\":{\"type\":\"string\",\"enum\":[\"hoje\",\"semana\",\"mes\"]}},\"required\":[\"period\"]}},\n    {\"name\":\"get_quota\",\"description\":\"Quota de queries do profissional hoje.\",\"input_schema\":{\"type\":\"object\",\"properties\":{}}}\n  ],\n  \"messages\": [\n    {\"role\": \"user\", \"content\": {{ JSON.stringify($('Parse Message').first().json.text) }}}\n  ]\n}",
        "options": {}
      },
