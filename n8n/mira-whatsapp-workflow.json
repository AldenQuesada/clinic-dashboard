    {
      "parameters": {
        "jsCode": "// Parseia resposta do Claude Haiku. Se tiver tool_use block, extrai.\nconst claude = $input.first().json;\nconst content = claude.content || [];\nconst toolBlock = content.find(c => c.type === 'tool_use');\n\nif (!toolBlock) {\n  // Claude respondeu em texto (nao escolheu tool)\n  const textBlock = content.find(c => c.type === 'text');\n  const response = (textBlock && textBlock.text) || '🤔 Nao entendi e nao tenho ferramenta pra isso.';\n  return [{ json: { needsTool: false, response } }];\n}\n\nreturn [{ json: {\n  needsTool: true,\n  tool_name: toolBlock.name,\n  tool_args: toolBlock.input || {}\n} }];"
      },
